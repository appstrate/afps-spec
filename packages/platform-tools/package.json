{
  "name": "@afps-spec/platform-tools",
  "version": "1.0.0",
  "description": "Reference TypeScript implementations of the five AFPS 1.3 reserved platform tools: log, memory, output, report, state.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./log": "./src/log.ts",
    "./memory": "./src/memory.ts",
    "./output": "./src/output.ts",
    "./report": "./src/report.ts",
    "./state": "./src/state.ts",
    "./manifests/*.json": "./manifests/*.json"
  },
  "files": [
    "src",
    "manifests",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "afps",
    "agent",
    "tool",
    "platform"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/appstrate/afps-spec",
    "directory": "packages/platform-tools"
  },
  "dependencies": {
    "@afps-spec/types": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "typescript": "^5"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  }
}
